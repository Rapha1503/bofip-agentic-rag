# BOFIP-RAG environment variables
# Copy this file to .env and fill in the values.

# REQUIRED: Groq API key (free tier available at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# --- Optional overrides (defaults are sensible) ---

# Embedding model used by sentence-transformers (768 dim, French-optimized)
# EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ChromaDB persistence directory
# CHROMA_DB_DIR=data/chroma_db

# Cross-encoder reranker pool size
# RERANK_POOL_SIZE=30

# LLM context budget (avoid Groq 413 payload errors)
# LLM_MAX_CONTEXT_CHUNKS=14
# LLM_MAX_CONTEXT_TOKENS=4500

# Faithfulness guardrail
# FAITHFULNESS_GUARDRAIL_ENABLED=true
# FAITHFULNESS_VERIFIER_MODEL=llama-3.1-8b-instant
# FAITHFULNESS_MIN_CONFIDENCE=0.55
# FAITHFULNESS_MAX_CONTEXT_CHUNKS=6
