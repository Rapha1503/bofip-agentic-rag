# Copy to .env.local for local development. Never commit real API keys.

# OpenAI-compatible LLM providers supported by the Streamlit app.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Optional: path to a local BOFiP export containing Contenu/**/document.xml
# and data.html/data.htm pairs for rebuilding raw documents.
RAW_BOFIP_ROOT=

# Optional: set to 1 only when you intentionally want local pipeline logs.
BOFIP_PIPELINE_LOG=0

# Optional: download missing runtime artifacts from the release URL.
BOFIP_AUTO_DOWNLOAD_ARTIFACTS=0
BOFIP_ARTIFACT_BASE_URL=https://github.com/Rapha1503/bofip-agentic-rag/releases/download/full-corpus-v1
BOFIP_VALIDATE_HASHES=0

# Optional: set to 1 to force local Hugging Face model files only.
BOFIP_LOCAL_FILES_ONLY=0
