# Copy to .env.local for local development. Never commit real API keys.

# LLM providers supported by the Streamlit app.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Optional: path to a local BOFiP export containing Contenu/**/document.xml
# and data.html/data.htm pairs for rebuilding raw documents.
RAW_BOFIP_ROOT=

# Optional: set to 1 only when you intentionally want local pipeline logs.
BOFIP_PIPELINE_LOG=0
